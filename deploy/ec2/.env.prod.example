# Copy this file to .env.prod and replace placeholders before running in EC2.
SPRING_PROFILES_ACTIVE=prod

# MySQL example:
# DB_URL=jdbc:mysql://<RDS_ENDPOINT>:3306/<DB_NAME>?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# PostgreSQL example:
# DB_URL=jdbc:postgresql://<RDS_ENDPOINT>:5432/<DB_NAME>

DB_URL=<SET_DB_URL>
DB_USERNAME=<SET_DB_USERNAME>
DB_PASSWORD=<SET_DB_PASSWORD>
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
